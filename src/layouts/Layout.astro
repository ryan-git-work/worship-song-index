---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  structuredData?: object;
  lang?: string;
  alternates?: Array<{ hreflang: string; href: string }>;
}

const { title, description, structuredData, lang = 'en', alternates = [] } = Astro.props;

const canonicalURL = `https://worshipsongindex.com${Astro.url.pathname}`;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Worship Song Index",
  "url": "https://worshipsongindex.com",
  "logo": "https://worshipsongindex.com/generated-icon.png",
  "description": "A free, structured worship-song reference for church worship leaders. Search 3,470+ worship songs by key, BPM, time signature, scripture, and theme."
};

// Normalize to an array so every page always gets Organization appended
const pageSchemas = structuredData
  ? (Array.isArray(structuredData) ? structuredData : [structuredData])
  : [];
const allSchemas = [organizationSchema, ...pageSchemas];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/generated-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
    ))}

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <script type="application/ld+json" set:html={JSON.stringify(allSchemas.length === 1 ? allSchemas[0] : allSchemas)} />
  </head>
  <body class="min-h-screen">
    <header class="border-b" style="border-color: var(--color-border);">
      <nav class="max-w-7xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5 text-xl font-semibold tracking-tight text-primary-700 hover:text-primary-800 transition-colors" style="font-family: var(--font-serif);">
          <img src="/generated-icon.png" alt="Worship Songs Logo" class="w-7 h-7" />
          Worship Song Index
        </a>
        <div class="flex items-center gap-8">
          <a href="/browse" class="text-sm font-medium transition-colors hover:text-primary-600" style="color: var(--color-text-secondary);">Browse</a>
          <a href="/blog" class="text-sm font-medium transition-colors hover:text-primary-600" style="color: var(--color-text-secondary);">Guides</a>
          <a href="/worship-team-devotionals/" class="text-sm font-medium transition-colors hover:text-primary-600" style="color: var(--color-text-secondary);">Devotionals</a>
        </div>
      </nav>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-10">
      <slot />
    </main>

    <footer class="border-t mt-16" style="border-color: var(--color-border);">
      <div class="max-w-7xl mx-auto px-6 py-8 text-center text-sm" style="color: var(--color-text-muted);">
        <p>Worship Song Index &mdash; Find the perfect songs for your worship service</p>
      </div>
    </footer>
  </body>
</html>
