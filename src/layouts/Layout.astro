---
import '../styles/global.css';
import SongSearch from '../components/SongSearch.astro';

interface Props {
  title: string;
  description: string;
  structuredData?: object;
  lang?: string;
  alternates?: Array<{ hreflang: string; href: string }>;
  fullWidth?: boolean;
}

const {
  title,
  description,
  structuredData,
  lang = 'en',
  alternates = [],
  fullWidth = false,
} = Astro.props;

const canonicalURL = `https://worshipsongindex.com${Astro.url.pathname}`;

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Worship Song Index",
  "url": "https://worshipsongindex.com",
  "logo": "https://worshipsongindex.com/generated-icon.png",
  "description": "A free worship-song reference for church worship leaders. Search 3,470+ worship songs by title or artist, then explore keys, BPM, time signature, scripture, meaning, and leadership notes."
};

// Normalize to an array so every page always gets Organization appended
const pageSchemas = structuredData
  ? (Array.isArray(structuredData) ? structuredData : [structuredData])
  : [];
const allSchemas = [organizationSchema, ...pageSchemas];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/generated-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalURL} />
    {alternates.map((alternate) => (
      <link rel="alternate" hreflang={alternate.hreflang} href={alternate.href} />
    ))}

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    <script type="application/ld+json" set:html={JSON.stringify(allSchemas.length === 1 ? allSchemas[0] : allSchemas)} />
  </head>
  <body class="min-h-screen">
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary navigation">
        <a href="/" class="site-brand">
          <img src="/generated-icon.png" alt="" width="30" height="30" />
          <span>Worship Song Index</span>
        </a>
        <div class="site-search">
          <SongSearch id="site-song-search" />
        </div>
        <div class="site-links">
          <a href="/songs/">Songs</a>
          <a href="/browse/">Browse</a>
          <a href="/articles/">Occasions</a>
          <a href="/worship-team-devotionals/">Devotionals</a>
        </div>
      </nav>
    </header>

    <main class:list={{ 'max-w-7xl mx-auto px-6 py-10': !fullWidth }}>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer__inner">
        <a href="/" class="site-footer__brand">Worship Song Index</a>
        <p>Free song data and pastoral notes for worship leaders.</p>
        <div class="site-footer__links">
          <a href="/songs/">All songs</a>
          <a href="/browse/">Browse</a>
          <a href="/blog/">Guides</a>
          <a href="/canciones/">Canciones</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .site-header {
    position: relative;
    z-index: 50;
    border-bottom: 1px solid var(--color-border);
    background: rgba(250, 249, 246, 0.97);
  }

  .site-nav {
    display: grid;
    grid-template-columns: auto minmax(15rem, 21rem) auto;
    align-items: center;
    gap: 1.5rem;
    max-width: 80rem;
    margin: 0 auto;
    padding: 0.85rem 1.5rem;
  }

  .site-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    color: var(--color-primary-800);
    font-family: var(--font-serif);
    font-size: 1.22rem;
    font-weight: 700;
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
  }

  .site-brand img {
    width: 1.875rem;
    height: 1.875rem;
  }

  .site-search {
    min-width: 0;
  }

  .site-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 1.25rem;
  }

  .site-links a,
  .site-footer a {
    color: var(--color-text-secondary);
    font-size: 0.82rem;
    font-weight: 600;
    text-decoration: none;
  }

  .site-links a:hover,
  .site-footer a:hover {
    color: var(--color-primary-700);
  }

  .site-footer {
    margin-top: 4rem;
    border-top: 1px solid var(--color-border);
    background: #f3f4f1;
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.5rem;
    max-width: 80rem;
    margin: 0 auto;
    padding: 2rem 1.5rem;
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .site-footer__brand {
    color: var(--color-primary-800) !important;
    font-family: var(--font-serif);
    font-size: 1rem !important;
  }

  .site-footer__links {
    display: flex;
    gap: 1.25rem;
  }

  @media (max-width: 1023px) {
    .site-nav {
      grid-template-columns: auto 1fr;
    }

    .site-search {
      grid-column: 1 / -1;
      grid-row: 2;
    }

    .site-search :global(.song-search) {
      width: 100%;
      max-width: none;
    }
  }

  @media (max-width: 639px) {
    .site-nav {
      gap: 0.8rem;
      padding: 0.7rem 1rem 0.85rem;
    }

    .site-brand span {
      font-size: 1.05rem;
    }

    .site-links {
      gap: 0.85rem;
    }

    .site-links a {
      font-size: 0.75rem;
    }

    .site-links a:nth-child(3),
    .site-links a:nth-child(4) {
      display: none;
    }

    .site-footer__inner {
      grid-template-columns: 1fr;
      gap: 0.65rem;
      padding: 1.6rem 1rem;
      text-align: left;
    }
  }
</style>
