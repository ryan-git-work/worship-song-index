---
interface Props {
  podcastUrl?: string;
  tccUrl?: string;
}

const { podcastUrl, tccUrl } = Astro.props;
---

{(podcastUrl || tccUrl) && (
  <div class="rounded-lg border p-6" style="background: var(--color-surface-card); border-color: var(--color-border);">
    <h3 class="text-lg font-semibold mb-4" style="font-family: var(--font-serif); color: var(--color-text-primary);">Related Resources</h3>
    <div class="space-y-3">
      {podcastUrl && (
        <a href={podcastUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-primary-600 hover:text-primary-800 transition-colors font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z" />
          </svg>
          Formation to Transformation Episode
        </a>
      )}
      {tccUrl && (
        <a href={tccUrl} target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-primary-600 hover:text-primary-800 transition-colors font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          {tccUrl}
        </a>
      )}
    </div>
  </div>
)}
