---
interface Props {
  title: string;
  artist: string;
  maleKey: string;
  femaleKey: string;
  tempo: string;
  bpm: number;
  timeSignature: string;
  slug: string;
}

const { title, artist, maleKey, femaleKey, tempo, bpm, timeSignature, slug } = Astro.props;
---

<a href={`/songs/${slug}`} class="block border-b transition-colors hover:bg-primary-50/40" style="border-color: var(--color-border-light);">
  <div class="flex items-center gap-4 py-3.5 px-4">
    <div class="flex-1 min-w-0">
      <h2 class="text-base font-medium truncate transition-colors" style="color: var(--color-text-primary); font-family: var(--font-serif);">
        {title}
      </h2>
      <p class="text-sm truncate" style="color: var(--color-text-muted);">{artist}</p>
    </div>

    <div class="hidden sm:flex items-center gap-1.5">
      <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-primary-100 text-primary-800">
        {maleKey}
      </span>
      <span class="inline-flex items-center px-2 py-0.5 rounded-md text-xs font-medium bg-accent-100 text-accent-800">
        {femaleKey}
      </span>
    </div>

    <div class="hidden md:flex items-center gap-3 text-sm" style="color: var(--color-text-muted);">
      <span class="w-16 text-right">{tempo}</span>
      <span class="w-16 text-right">{bpm} BPM</span>
      <span class="w-12 text-center px-2 py-0.5 rounded-md text-xs" style="background: var(--color-border-light);">{timeSignature}</span>
    </div>

    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" style="color: var(--color-text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>
