---
import Layout from '../../../layouts/Layout.astro';
import { songs } from '../../../lib/songs';
import { slugifyBrowseValue } from '../../../lib/browseSlugs';

const artistCounts: Record<string, number> = {};
const allArtists = [...new Set(songs.map(s => s.primary_artist))].sort();

allArtists.forEach(artist => {
  const artistLower = artist.toLowerCase();
  artistCounts[artist] = songs.filter(s => {
    const songArtist = (s.primary_artist || '').toLowerCase();
    return songArtist === artistLower || songArtist.includes(artistLower);
  }).length;
});

const title = "Browse by Artist - Worship Song Index";
const description = `Browse worship songs from ${allArtists.length} artists and worship bands. Find songs from Hillsong, Elevation, Bethel, and more.`;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Browse Worship Songs by Artist",
  "description": description,
  "url": "https://worshipsongindex.com/browse/artists",
  "numberOfItems": allArtists.length,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://worshipsongindex.com" },
      { "@type": "ListItem", "position": 2, "name": "Browse", "item": "https://worshipsongindex.com/browse" },
      { "@type": "ListItem", "position": 3, "name": "Artists", "item": "https://worshipsongindex.com/browse/artists" }
    ]
  }
};
---

<Layout title={title} description={description} structuredData={structuredData}>
  <nav class="mb-8 text-sm" style="color: var(--color-text-muted);">
    <a href="/" class="text-primary-600 hover:text-primary-800 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <a href="/browse" class="text-primary-600 hover:text-primary-800 transition-colors">Browse</a>
    <span class="mx-2">/</span>
    <span>Artists</span>
  </nav>

  <div class="mb-10">
    <h1 class="text-3xl md:text-4xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-text-primary);">Browse by Artist</h1>
    <p class="text-lg" style="color: var(--color-text-secondary);">Find worship songs from {allArtists.length} artists and bands.</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
    {allArtists.map(artist => (
      <a
        href={`/browse/artists/${slugifyBrowseValue(artist)}/`}
        class="p-4 rounded-lg border transition-all duration-200 hover:shadow-md hover:border-primary-300 flex justify-between items-center"
        style="background: var(--color-surface-card); border-color: var(--color-border);"
      >
        <span class="font-medium" style="color: var(--color-text-primary);">{artist}</span>
        <span class="text-xs px-2 py-1 rounded-md" style="background: var(--color-border-light); color: var(--color-text-muted);">{artistCounts[artist]} songs</span>
      </a>
    ))}
  </div>

  <div class="mt-12">
    <a href="/browse" class="text-primary-600 hover:text-primary-800 font-medium flex items-center gap-1 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Browse
    </a>
  </div>
</Layout>
