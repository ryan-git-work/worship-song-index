---
import Layout from '../../../../layouts/Layout.astro';
import SongCard from '../../../../components/SongCard.astro';
import type { Song } from '../../../../types/song';
import { getTempoLabel } from '../../../../types/song';
import songsData from '../../../../../public/songs.json';
import { getKeyDescription } from '../../../../lib/keyDescriptions';
import editorialsData from '../../../../../public/browse-editorials.json';
import { marked } from 'marked';

export async function getStaticPaths() {
  const songs: Song[] = songsData as Song[];
  const allKeys = [...new Set(songs.map(s => s.default_female_key))];

  return allKeys.map(key => ({
    params: { key: key.replace('#', '-sharp').toLowerCase() },
    props: { key }
  }));
}

const { key } = Astro.props;
const keySlug = Astro.params.key;
const keyDescription = getKeyDescription(keySlug);
const songs: Song[] = songsData as Song[];
const filteredSongs = songs.filter(s => s.default_female_key === key).sort((a, b) => a.title.localeCompare(b.title));

const isKeyF = key === 'F';

const title = isKeyF
  ? 'Worship Songs in the Key of F (Female Voice) | BPM & Tempo — Worship Song Index'
  : `Worship Songs in the Key of ${key} (Female Voice) | BPM & Tempo — Worship Song Index`;

const description = isKeyF
  ? 'Browse worship songs in the key of F for female vocalists, complete with BPM, tempo, and time signature. The most popular female key in modern worship — find your next set here.'
  : `Browse worship songs in the key of ${key} for female vocalists, with BPM, tempo, and time signature for every song. Find the perfect key for your worship team.`;

function formatKey(slug: string): string {
  return slug.replace(/\b([a-g])-sharp\b/gi, (_m, letter: string) => letter.toUpperCase() + '#');
}

const displayKey = formatKey(keySlug);

const editorialEntry = (editorialsData as any)["keys-female"]?.[keySlug || ''];
const editorialHtml = editorialEntry?.editorial_markdown ? marked.parse(editorialEntry.editorial_markdown) : null;

const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `Worship Songs in the Key of ${displayKey} (Female Voice)`,
  "description": `${filteredSongs.length} worship songs in the key of ${displayKey} for female vocalists, with BPM and time signature for each.`,
  "numberOfItems": filteredSongs.length,
  "itemListElement": filteredSongs.slice(0, 30).map((song, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://worshipsongindex.com/songs/${song.slug}`,
    "name": song.title
  }))
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://worshipsongindex.com" },
    { "@type": "ListItem", "position": 2, "name": "Browse", "item": "https://worshipsongindex.com/browse" },
    { "@type": "ListItem", "position": 3, "name": `Female Key: ${displayKey}`, "item": `https://worshipsongindex.com${Astro.url.pathname}` }
  ]
};

const structuredData = [itemList, breadcrumb];
---

<Layout title={title} description={description} structuredData={structuredData}>
  <nav class="mb-8 text-sm" style="color: var(--color-text-muted);">
    <a href="/" class="text-primary-600 hover:text-primary-800 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <a href="/browse" class="text-primary-600 hover:text-primary-800 transition-colors">Browse</a>
    <span class="mx-2">/</span>
    <span>Female Key: {key}</span>
  </nav>

  <div class="mb-10">
    <h1 class="text-3xl md:text-4xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-text-primary);">
      {isKeyF ? 'Worship Songs in the Key of F (Female Voice)' : `Female Key: ${key}`}
    </h1>
    <p style="color: var(--color-text-muted);">Showing {filteredSongs.length} songs</p>
  </div>

  {keyDescription && (
    <p class="mb-10 text-base leading-relaxed max-w-3xl" style="color: var(--color-text-secondary);">
      {keyDescription}
    </p>
  )}

  {isKeyF && (
    <p class="mb-10 text-base leading-relaxed max-w-3xl" style="color: var(--color-text-secondary);">
      F major is the most common key for female vocalists in modern worship — and the sheer size of this catalog reflects that. It sits in a sweet spot for many female voices, offering enough range to feel expressive without pushing into uncomfortable territory. Songs like What A Beautiful Name, Way Maker, Oceans, and King of Kings all land here, making F one of the most versatile and well-stocked keys you can plan around. One practical note: nearly every song on this page pairs with D for a male vocalist, so if you're planning a male-led set in D or a mixed-lead service, this list is your matching resource. Browse by tempo and time signature below to find songs that fit your vocalist and your set.
    </p>
  )}

  {editorialHtml && (
    <article class="mb-12 max-w-3xl prose prose-lg" style="color: var(--color-text-secondary);" set:html={editorialHtml} />
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    {filteredSongs.map(song => (
      <SongCard
        title={song.title}
        artist={song.primary_artist}
        maleKey={song.default_male_key}
        femaleKey={song.default_female_key}
        tempo={getTempoLabel(song.tempo_bpm)}
        bpm={song.tempo_bpm}
        timeSignature={song.time_signature}
        slug={song.slug}
      />
    ))}
  </div>

  <div class="mt-12">
    <a href="/browse" class="text-primary-600 hover:text-primary-800 font-medium flex items-center gap-1 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Browse All Categories
    </a>
  </div>

  {isKeyF && (
    <div class="mt-12 pt-8 border-t" style="border-color: var(--color-border);">
      <p class="text-sm font-medium mb-3" style="color: var(--color-text-muted);">Looking for other keys?</p>
      <div class="text-sm space-y-2" style="color: var(--color-text-secondary);">
        <p>
          Browse female keys:{' '}
          <a href="/browse/keys/female/a" class="text-primary-600 hover:text-primary-800 transition-colors">A</a>
          {' · '}
          <a href="/browse/keys/female/b-sharp" class="text-primary-600 hover:text-primary-800 transition-colors">Bb</a>
          {' · '}
          <a href="/browse/keys/female/c" class="text-primary-600 hover:text-primary-800 transition-colors">C</a>
          {' · '}
          <a href="/browse/keys/female/d" class="text-primary-600 hover:text-primary-800 transition-colors">D</a>
          {' · '}
          <a href="/browse/keys/female/e" class="text-primary-600 hover:text-primary-800 transition-colors">E</a>
          {' · '}
          <a href="/browse/keys/female/g" class="text-primary-600 hover:text-primary-800 transition-colors">G</a>
        </p>
        <p>
          Browse male keys:{' '}
          <a href="/browse/keys/male/d" class="text-primary-600 hover:text-primary-800 transition-colors">D</a>
          {' · '}
          <a href="/browse/keys/male/g" class="text-primary-600 hover:text-primary-800 transition-colors">G</a>
        </p>
      </div>
    </div>
  )}
</Layout>
