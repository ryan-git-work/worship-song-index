---
import Layout from '../../../layouts/Layout.astro';
import SongCard from '../../../components/SongCard.astro';
import { getTempoLabel, formatTheme } from '../../../types/song';
import { songs } from '../../../lib/songs';
import { slugifyBrowseValue } from '../../../lib/browseSlugs';
import editorialsData from '../../../../public/browse-editorials.json';
import { marked } from 'marked';

export async function getStaticPaths() {
  const tagBySlug = new Map<string, string>();
  const artistSlugs = new Set(songs.map((song) => slugifyBrowseValue(song.primary_artist)));
  songs.flatMap(s => s.tags).forEach((tag) => {
    const slug = slugifyBrowseValue(tag);
    if (artistSlugs.has(slug)) return;
    if (!tagBySlug.has(slug)) tagBySlug.set(slug, tag);
  });

  return Array.from(tagBySlug.entries()).map(([tagSlug, tag]) => ({
    params: { tag: tagSlug },
    props: { tag, tagSlug }
  }));
}

const { tag, tagSlug } = Astro.props;
const filteredSongs = songs
  .filter(s => s.tags.some((songTag) => slugifyBrowseValue(songTag) === tagSlug))
  .sort((a, b) => a.title.localeCompare(b.title));

const title = `${formatTheme(tag)} Worship Songs | BPM, Tempo & Keys — Worship Song Index`;
const description = `Browse ${filteredSongs.length} worship songs tagged "${formatTheme(tag)}". Find songs with the ${formatTheme(tag).toLowerCase()} style for your worship set.`;

const editorialEntry = (editorialsData as any)["tags"]?.[tagSlug || ''];
const editorialHtml = editorialEntry?.editorial_markdown ? marked.parse(editorialEntry.editorial_markdown) : null;

const collectionPage = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": `${formatTheme(tag)} Worship Songs`,
  "description": description,
  "url": `https://worshipsongindex.com/browse/tags/${tagSlug}/`,
  "numberOfItems": filteredSongs.length
};

const itemList = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": `${formatTheme(tag)} Worship Songs`,
  "description": `${filteredSongs.length} worship songs on the theme of ${formatTheme(tag)}, with keys, BPM, and tempo for each.`,
  "numberOfItems": filteredSongs.length,
  "itemListElement": filteredSongs.slice(0, 30).map((song, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "url": `https://worshipsongindex.com/songs/${song.slug}`,
    "name": song.title
  }))
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://worshipsongindex.com" },
    { "@type": "ListItem", "position": 2, "name": "Browse", "item": "https://worshipsongindex.com/browse" },
    { "@type": "ListItem", "position": 3, "name": "Categories", "item": "https://worshipsongindex.com/browse/categories" },
    { "@type": "ListItem", "position": 4, "name": formatTheme(tag), "item": `https://worshipsongindex.com/browse/tags/${tagSlug}/` }
  ]
};

const structuredData = [collectionPage, breadcrumb, itemList];
---

<Layout title={title} description={description} structuredData={structuredData}>
  <nav class="mb-8 text-sm" style="color: var(--color-text-muted);">
    <a href="/" class="text-primary-600 hover:text-primary-800 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <a href="/browse" class="text-primary-600 hover:text-primary-800 transition-colors">Browse</a>
    <span class="mx-2">/</span>
    <a href="/browse/categories" class="text-primary-600 hover:text-primary-800 transition-colors">Categories</a>
    <span class="mx-2">/</span>
    <span>{formatTheme(tag)}</span>
  </nav>

  <div class="mb-10">
    <h1 class="text-3xl md:text-4xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-text-primary);">
      Tag: {formatTheme(tag)}
    </h1>
    <p style="color: var(--color-text-muted);">Showing {filteredSongs.length} songs</p>
  </div>

  {editorialHtml && (
    <article class="mb-12 max-w-3xl prose prose-lg" style="color: var(--color-text-secondary);" set:html={editorialHtml} />
  )}

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
    {filteredSongs.map(song => (
      <SongCard
        title={song.title}
        artist={song.primary_artist}
        maleKey={song.default_male_key}
        femaleKey={song.default_female_key}
        tempo={getTempoLabel(song.tempo_bpm)}
        bpm={song.tempo_bpm}
        timeSignature={song.time_signature}
        slug={song.slug}
      />
    ))}
  </div>

  <div class="mt-12">
    <a href="/browse/categories" class="text-primary-600 hover:text-primary-800 font-medium flex items-center gap-1 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to Categories
    </a>
  </div>
</Layout>
