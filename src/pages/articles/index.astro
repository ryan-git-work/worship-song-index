---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const articles = (await getCollection('articles')).sort((a, b) =>
  a.data.target_occasion.localeCompare(b.data.target_occasion)
);

const title = 'Worship Occasion Song Guides — Worship Song Index';
const description = 'Browse worship song guides for church calendar moments, pastoral occasions, and special services.';
const canonicalURL = 'https://worshipsongindex.com/articles/';

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Worship Occasion Song Guides",
  "description": description,
  "url": canonicalURL,
  "numberOfItems": articles.length,
  "itemListElement": articles.map((entry, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "name": entry.data.meta_title,
    "url": `https://worshipsongindex.com/articles/${entry.data.slug}/`
  }))
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://worshipsongindex.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Articles",
      "item": canonicalURL
    }
  ]
};
---

<Layout title={title} description={description} structuredData={[itemListSchema, breadcrumbSchema]}>
  <nav class="mb-8 text-sm" style="color: var(--color-text-muted);">
    <a href="/" class="text-primary-600 hover:text-primary-800 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <span>Articles</span>
  </nav>

  <header class="mb-10 max-w-3xl">
    <p class="text-sm font-medium uppercase tracking-widest mb-3" style="color: var(--color-text-muted);">
      Worship Planning
    </p>
    <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-5" style="font-family: var(--font-serif); color: var(--color-text-primary);">
      Worship Occasion Song Guides
    </h1>
    <p class="text-lg leading-relaxed" style="color: var(--color-text-secondary);">
      Service-specific song planning guides for church calendar moments, pastoral occasions, and special Sundays.
    </p>
  </header>

  <section class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {articles.map((entry) => (
      <a
        href={`/articles/${entry.data.slug}/`}
        class="block rounded-lg border p-5 transition-colors hover:border-primary-300"
        style="background: var(--color-surface-card); border-color: var(--color-border);"
      >
        <h2 class="text-xl font-semibold leading-snug mb-3" style="font-family: var(--font-serif); color: var(--color-text-primary);">
          {entry.data.target_occasion}
        </h2>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-text-secondary);">
          {entry.data.meta_description}
        </p>
        <p class="text-xs" style="color: var(--color-text-muted);">
          {entry.data.song_links_count} song links
        </p>
      </a>
    ))}
  </section>
</Layout>
