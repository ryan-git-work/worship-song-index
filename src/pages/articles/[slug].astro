---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');

  return articles.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const canonicalURL = `https://worshipsongindex.com/articles/${entry.data.slug}/`;
const publishedDate =
  entry.data.created instanceof Date
    ? entry.data.created.toISOString()
    : new Date(entry.data.created).toISOString();

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.meta_title,
  "description": entry.data.meta_description,
  "url": canonicalURL,
  "datePublished": publishedDate,
  "dateModified": publishedDate,
  "author": {
    "@type": "Organization",
    "name": "Worship Song Index",
    "url": "https://worshipsongindex.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Worship Song Index",
    "url": "https://worshipsongindex.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://worshipsongindex.com/generated-icon.png"
    }
  },
  "about": {
    "@type": "Thing",
    "name": entry.data.target_occasion
  },
  "wordCount": entry.data.word_count,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalURL
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://worshipsongindex.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Articles",
      "item": "https://worshipsongindex.com/articles/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": entry.data.target_occasion,
      "item": canonicalURL
    }
  ]
};

const structuredData = [articleSchema, breadcrumbSchema];
---

<Layout title={entry.data.meta_title} description={entry.data.meta_description} structuredData={structuredData}>
  <nav class="mb-8 text-sm" style="color: var(--color-text-muted);">
    <a href="/" class="text-primary-600 hover:text-primary-800 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <span>Articles</span>
    <span class="mx-2">/</span>
    <span>{entry.data.target_occasion}</span>
  </nav>

  <article class="max-w-3xl">
    <header class="mb-10">
      <p class="text-sm font-medium uppercase tracking-widest mb-3" style="color: var(--color-text-muted);">
        Occasion Guide
      </p>
      <h1 class="text-4xl md:text-5xl font-bold leading-tight mb-5" style="font-family: var(--font-serif); color: var(--color-text-primary);">
        {entry.data.target_occasion} Worship Songs
      </h1>
      <p class="text-lg leading-relaxed" style="color: var(--color-text-secondary);">
        {entry.data.meta_description}
      </p>
      <div class="mt-5 flex flex-wrap gap-3 text-sm" style="color: var(--color-text-muted);">
        <span>{entry.data.word_count.toLocaleString()} words</span>
        <span aria-hidden="true">/</span>
        <span>{entry.data.song_links_count} song links</span>
      </div>
    </header>

    <div
      class="prose prose-lg max-w-none"
      style="color: var(--color-text-secondary); --tw-prose-headings: var(--color-text-primary); --tw-prose-links: var(--color-primary-600); --tw-prose-bold: var(--color-text-primary); --tw-prose-body: var(--color-text-secondary);"
    >
      <Content />
    </div>

    <div class="mt-10 pt-8 border-t" style="border-color: var(--color-border);">
      <a href="/browse" class="text-sm font-semibold text-primary-600 hover:text-primary-800 transition-colors">
        Browse the full worship song index →
      </a>
    </div>
  </article>
</Layout>
