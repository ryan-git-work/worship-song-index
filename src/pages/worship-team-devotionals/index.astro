---
import Layout from '../../layouts/Layout.astro';
import PillarCards from '../../components/PillarCards.astro';
import { getEntry, render } from 'astro:content';

const hub = await getEntry('devotionalHubs', 'index');
if (!hub) throw new Error('Index hub not found');
const { Content } = await render(hub);

const title = "Worship Team Devotionals | Short Scripture-Based Devotions for Rehearsal & Sunday — Worship Song Index";
const description = "Short 5-10 minute worship team devotionals anchored in Scripture. Built for before rehearsal, soundcheck, or Sunday call time. Covers heart and motives, team culture, pastoral leadership, congregational worship, and more.";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": hub.data.title,
  "description": description,
  "url": "https://worshipsongindex.com/worship-team-devotionals/",
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://worshipsongindex.com" },
      { "@type": "ListItem", "position": 2, "name": "Devotionals", "item": "https://worshipsongindex.com/worship-team-devotionals/" }
    ]
  }
};
---

<Layout title={title} description={description} structuredData={structuredData}>
  <nav class="text-sm mb-8" style="color: var(--color-text-muted);">
    <a href="/" class="text-primary-600 hover:text-primary-800 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <span>Devotionals</span>
  </nav>

  <div class="mb-10">
    <h1 class="text-3xl md:text-4xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-text-primary);">{hub.data.title}</h1>
    <p class="text-lg max-w-3xl" style="color: var(--color-text-secondary);">{hub.data.description}</p>
  </div>

  <div class="prose prose-lg max-w-none mb-14" style="color: var(--color-text-secondary);">
    <Content />
  </div>

  <section class="mb-14">
    <h2 class="text-2xl font-semibold mb-6" style="font-family: var(--font-serif); color: var(--color-text-primary);">Explore by Topic</h2>
    <PillarCards />
  </section>

  <div class="rounded-lg p-8 text-center border bg-primary-50 border-primary-100">
    <h2 class="text-xl font-semibold text-primary-800 mb-2" style="font-family: var(--font-serif);">Looking for worship songs?</h2>
    <p class="text-primary-700 mb-4">Browse our song index to find the right songs for your worship set.</p>
    <a href="/" class="inline-flex items-center px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors font-medium">
      Browse Songs
    </a>
  </div>
</Layout>
