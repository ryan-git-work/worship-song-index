---
import Layout from '../../layouts/Layout.astro';
import { getEntry, getCollection, render } from 'astro:content';

const pillarSlugs = [
  'heart-and-motives',
  'team-culture-and-unity',
  'sustainable-ministry',
  'excellence-and-craft',
  'pastoral-leadership',
  'congregational-worship',
  'presence-and-prayer',
];

export function getStaticPaths() {
  return [
    { params: { pillar: 'heart-and-motives' } },
    { params: { pillar: 'team-culture-and-unity' } },
    { params: { pillar: 'sustainable-ministry' } },
    { params: { pillar: 'excellence-and-craft' } },
    { params: { pillar: 'pastoral-leadership' } },
    { params: { pillar: 'congregational-worship' } },
    { params: { pillar: 'presence-and-prayer' } },
  ];
}

const { pillar } = Astro.params;
const hub = await getEntry('devotionalHubs', pillar!);
if (!hub) throw new Error(`Hub not found: ${pillar}`);
const { Content } = await render(hub);

const allDevotionals = await getCollection('devotionals');
const devotionals = allDevotionals.filter((d) => d.data.pillar === pillar);

const title = hub.data.title + " - Worship Team Devotionals";
const description = hub.data.description;

const structuredData = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": hub.data.title,
  "description": description,
  "url": `https://worshipsongindex.com/worship-team-devotionals/${pillar}/`,
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://worshipsongindex.com" },
      { "@type": "ListItem", "position": 2, "name": "Devotionals", "item": "https://worshipsongindex.com/worship-team-devotionals/" },
      { "@type": "ListItem", "position": 3, "name": hub.data.title, "item": `https://worshipsongindex.com/worship-team-devotionals/${pillar}/` }
    ]
  }
};
---

<Layout title={title} description={description} structuredData={structuredData}>
  <nav class="text-sm mb-8" style="color: var(--color-text-muted);">
    <a href="/" class="text-primary-600 hover:text-primary-800 transition-colors">Home</a>
    <span class="mx-2">/</span>
    <a href="/worship-team-devotionals/" class="text-primary-600 hover:text-primary-800 transition-colors">Devotionals</a>
    <span class="mx-2">/</span>
    <span>{hub.data.title}</span>
  </nav>

  <div class="mb-10">
    <h1 class="text-3xl md:text-4xl font-bold mb-3" style="font-family: var(--font-serif); color: var(--color-text-primary);">{hub.data.title}</h1>
    <p class="text-lg max-w-3xl" style="color: var(--color-text-secondary);">{hub.data.description}</p>
  </div>

  <div class="prose prose-lg max-w-none mb-14" style="color: var(--color-text-secondary);">
    <Content />
  </div>

  {devotionals.length > 0 ? (
    <section class="space-y-4">
      <h2 class="text-2xl font-semibold mb-5" style="font-family: var(--font-serif); color: var(--color-text-primary);">Devotionals</h2>
      {devotionals.map((devo) => (
        <a href={`/worship-team-devotionals/${pillar}/${devo.id.split('/').pop()}/`} class="block rounded-lg border p-6 transition-all duration-200 hover:shadow-md hover:-translate-y-0.5 hover:border-primary-300" style="background: var(--color-surface-card); border-color: var(--color-border);">
          <h3 class="text-lg font-semibold text-primary-700 mb-1" style="font-family: var(--font-serif);">{devo.data.title}</h3>
          <p class="text-sm mb-2" style="color: var(--color-text-muted);">{devo.data.verseRef}</p>
          <p style="color: var(--color-text-secondary);">{devo.data.description}</p>
        </a>
      ))}
    </section>
  ) : (
    <div class="rounded-lg p-8 text-center border" style="background: var(--color-surface); border-color: var(--color-border);">
      <p style="color: var(--color-text-secondary);">Devotionals for this topic are coming soon.</p>
    </div>
  )}

  <div class="mt-12">
    <a href="/worship-team-devotionals/" class="text-primary-600 hover:text-primary-800 font-medium flex items-center gap-1 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      All Devotional Topics
    </a>
  </div>
</Layout>
