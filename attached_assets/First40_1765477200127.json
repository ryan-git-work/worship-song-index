  \{\
    "slug": "in-christ-alone",\
    "title": "In Christ Alone",\
    "primary_artist": "Keith Getty & Stuart Townend",\
    "default_male_key": "D",\
    "default_female_key": "F",\
    "tempo_bpm": 68,\
